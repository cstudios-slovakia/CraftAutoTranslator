{% set sites = craft.app.sites.allSites %}
{% set currentSiteId = currentSiteId ?? element.siteId %}
{% if sites|length > 1 %}
    <div id="auto-translator-sidebar" class="meta" style="margin-top: 20px; border-top: 1px solid rgba(0, 0, 0, 0.1); padding-top: 20px;">
        <div class="data">
            <h5 class="heading">Auto Translator</h5>
            <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 10px;">
                <button type="button" class="btn submit auto-translator-trigger-btn" data-target="all" style="width: 100%; justify-content: center;">
                    Translate to All Sites
                </button>
                {% for site in sites %}
                    {% if site.id != currentSiteId %}
                        <button type="button" class="btn auto-translator-trigger-btn" data-target="{{ site.id }}" style="width: 100%; justify-content: center; border-color: #2782c3; color: #2782c3;">
                            Translate to {{ site.name }}
                        </button>
                    {% endif %}
                {% endfor %}
                <div id="auto-translator-status" style="font-size: 12px; color: green; display: none; text-align: center;">Queued!</div>
            </div>
        </div>
    </div>

    {% js %}
        $(document).ready(function() {
            var $sidebar = $('#settings');
            if ($sidebar.length === 0) {
                $sidebar = $('#details'); // Fallback for some layouts
            }
            if ($sidebar.length > 0) {
                $sidebar.append($('#auto-translator-sidebar'));
            }

            $('.auto-translator-trigger-btn').on('click', function(e) {
                e.preventDefault();
                var $btn = $(this);
                var targetSiteId = $btn.data('target');

                $btn.addClass('loading').attr('disabled', true);
                $('#auto-translator-status').hide();

                var payload = {
                    elementId: {{ element.id }},
                    sourceSiteId: {{ currentSiteId }},
                    targetSiteId: targetSiteId
                };

                var done = function(success, errorMsg) {
                    $btn.removeClass('loading').attr('disabled', false);
                    if (success) {
                        $('#auto-translator-status').text('Translation queued!').show();
                        setTimeout(function() { $('#auto-translator-status').fadeOut(); }, 3000);
                    } else {
                        Craft.cp.displayError(errorMsg || 'Failed to trigger translation.');
                    }
                };

                if (typeof Craft.sendActionRequest === 'function') {
                    Craft.sendActionRequest('POST', 'auto-translator/translate/element', { data: payload })
                        .then(function(response) {
                            done(!!(response && response.data && response.data.success !== false), response && response.data && response.data.error);
                        })
                        .catch(function(e) {
                            done(false, (e && e.response && e.response.data && e.response.data.error) || (e && e.message));
                        });
                } else if (typeof Craft.postActionRequest === 'function') {
                    // Legacy fallback (Craft 3/early 4)
                    Craft.postActionRequest('auto-translator/translate/element', payload, function(response, textStatus) {
                        done(textStatus === 'success' && response && response.success, response && response.error);
                    });
                } else {
                    done(false, 'Craft action request helper not available.');
                }
            });
        });
    {% endjs %}
{% endif %}
