{
  "name": "cstudios/craft-auto-translator",
  "description": "Auto translate entries, commerce products, and solspace calendar events using OpenAI.",
  "type": "craft-plugin",
  "version": "1.0.0",
  "keywords": [
    "craft",
    "cms",
    "craftcms",
    "craft-plugin",
    "auto translator"
  ],
  "support": {
    "docs": "https://github.com/cstudios-slovakia/CraftAutoTranslator",
    "issues": "https://github.com/cstudios-slovakia/CraftAutoTranslator/issues"
  },
  "license": "MIT",
  "authors": [
    {
      "name": "cstudios",
      "homepage": "https://cstudios.sk"
    }
  ],
  "require": {
    "craftcms/cms": "^5.0.0",
    "openai-php/client": "^0.8.4"
  },
  "autoload": {
    "psr-4": {
      "cstudios\\autotranslator\\": "src/"
    }
  },
  "extra": {
    "name": "Auto Translator",
    "handle": "auto-translator",
    "hasCpSettings": true,
    "hasCpSection": false,
    "class": "cstudios\\autotranslator\\AutoTranslator"
  }
}
